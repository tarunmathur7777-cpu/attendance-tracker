{
  "manifest_version": 3,
  "name": "Attendance Extractor Pro",
  "version": "2.0.0",
  "description": "Extracts attendance data and automatically syncs it without manual clicking.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://localhost/*"],
      "js": ["content_app.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
